{
  "name": "hopkins-resume",
  "version": "1.0.0",
  "bin": {
    "hopkins-resume": "bin/hopkins-resume.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "lint:js": "eslint 'site-contents/js/main.js'",
    "lint:html": "htmlhint 'site-contents/**/*.html'",
    "lint": "npm run lint:js && npm run lint:html",
    "format": "prettier --write 'site-contents/**/*.{js,html,css}'",
    "format:check": "prettier --check 'site-contents/**/*.{js,html,css}'",
    "ci": "npm run lint && npm run format:check && npm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "aws-cdk": "2.1120.0",
    "eslint": "^8.57.1",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.252.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  }
}
